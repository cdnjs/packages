{
  "name": "ebolax-animated-icons",
  "description": "Lightweight, CSS-only animated icons for Lucide, Heroicons and Iconoir.",
  "keywords": [
    "icons",
    "animated-icons",
    "animation",
    "ui",
    "web"
  ],
  "filename": "animated-icons.bundle.min.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebolax/animated-icons.git"
  },
  "autoupdate": {
    "source": "npm",
    "target": "@ebolax/animated-icons",
    "fileMap": [
      {
        "basePath": "dist",
        "files": [
          "*.css",
          "aic-icons/*.svg"
        ]
      }
    ]
  }
}
